rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Rule 1)
    match /{document=**} {
      allow read, write: if false;
    }
    
    // ----------------------------------------------------
    // Primatives (Phase 3)
    // ----------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isDirectrice() {
      return isSignedIn() && (
        request.auth.token.email == "romarichirsein@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "directrice")
      );
    }
    
    function isStaff() {
      return isSignedIn() && (
        request.auth.token.email == "romarichirsein@gmail.com" ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
      );
    }
    
    function getStaffCampusId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.campusId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // ----------------------------------------------------
    // Validation Blueprints (Pillar 2)
    // ----------------------------------------------------
    function isValidStudent(data) {
      return data.keys().hasAll([
        "id", "firstName", "lastName", "birthDate", "phone", "email",
        "parentName", "parentPhone", "campusId", "classId", "status",
        "enrollmentDate", "expirationDate", "totalAmount", "paidAmount",
        "balance", "createdBy", "createdAt", "updatedAt"
      ]) &&
      data.keys().size() >= 18 && data.keys().size() <= 22 &&
      data.id is string && data.id.size() <= 64 &&
      data.firstName is string && data.firstName.size() <= 100 &&
      data.lastName is string && data.lastName.size() <= 100 &&
      data.phone is string && data.phone.size() <= 30 &&
      data.email is string && data.email.size() <= 100 &&
      data.campusId is string && data.campusId.size() <= 64 &&
      data.classId is string && data.classId.size() <= 64 &&
      data.status in ["actif", "en_attente", "expiré", "terminé", "archivé"] &&
      data.totalAmount is number &&
      data.paidAmount is number &&
      data.balance is number &&
      (!data.keys().hasAll(["tags"]) || data.tags is list);
    }

    function isValidClass(data) {
      return data.keys().hasAll([
        "id", "language", "level", "period", "teacherId", "campusId",
        "maxStudents", "currentCount", "startDate", "endDate", "isActive"
      ]) &&
      data.keys().size() >= 11 && data.keys().size() <= 12 &&
      data.id is string && data.id.size() <= 64 &&
      data.language is string &&
      data.level in ["A1", "A2", "B1", "B2", "C1", "C2"] &&
      data.period in ["8h", "12h", "15h", "17h"] &&
      data.maxStudents is number && data.maxStudents > 0 &&
      data.currentCount is number && data.currentCount >= 0;
    }

    function isValidPayment(data) {
      return data.keys().hasAll([
        "id", "studentId", "amount", "date", "mode", "recordedBy"
      ]) &&
      data.keys().size() >= 6 && data.keys().size() <= 8 &&
      data.id is string && data.id.size() <= 64 &&
      data.studentId is string && data.studentId.size() <= 64 &&
      data.amount is number && data.amount > 0 &&
      data.mode in ["Espèces", "Mobile Money", "Virement"];
    }

    // ----------------------------------------------------
    // Collection Rules matches
    // ----------------------------------------------------
    
    // ----------------------------------------------------
    // Collection Rules matches (SaaS Presentation Mode Support)
    // ----------------------------------------------------
    
    // 1. Users collection
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // 2. Campuses collection
    match /campuses/{campusId} {
      allow read, write: if true;
    }
    
    // 3. Teachers collection
    match /teachers/{teacherId} {
      allow read, write: if true;
    }
    
    // 4. Classes collection
    match /classes/{classId} {
      allow read, write: if true;
    }
    
    // 5. Students collection
    match /students/{studentId} {
      allow read, write: if true;
    }
    
    // 6. Payments collection
    match /payments/{paymentId} {
      allow read, write: if true;
    }
    
    // 7. Audit Logs collection
    match /audit_logs/{logId} {
      allow read, create: if true;
      allow update, delete: if false; // Audit logs remain historically immutable
    }
    
    // 8. Waitlist collection
    match /waitlist/{waitlistId} {
      allow read, write: if true;
    }
    
    // 9. School custom configuration settings
    match /school_config/{configId} {
      allow read, write: if true;
    }
    
    // 10. Reminders collection
    match /reminders/{reminderId} {
      allow read, write: if true;
    }

    // 11. Schools collection
    match /schools/{schoolId} {
      allow read, write: if true;
    }

    // 12. Plans config collection
    match /plans_config/{planId} {
      allow read, write: if true;
    }

    // 13. System notifications collection
    match /system_notifications/{notifId} {
      allow read, write: if true;
    }
  }
}
